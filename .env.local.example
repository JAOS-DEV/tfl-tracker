TFL_API_KEY=your_tfl_api_key_here
NEXT_PUBLIC_ENABLE_ADVANCED_DIAGNOSTICS=false
NEXT_PUBLIC_ENABLE_AFTER_MIDNIGHT_REPLAY=false

# Developer tools default on locally and off in production.
# Set explicitly at build time to override either default.
# NEXT_PUBLIC_ENABLE_ADVANCED_DIAGNOSTICS=true
# NEXT_PUBLIC_ENABLE_AFTER_MIDNIGHT_REPLAY=true

# Optional map tiles for the interactive route map tab
# NEXT_PUBLIC_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
# NEXT_PUBLIC_MAP_TILE_ATTRIBUTION=© OpenStreetMap contributors

# Optional: external compact iBus static JSON host (folder containing current.json)
# NEXT_PUBLIC_IBUS_DATA_BASE_URL=https://your-static-host.example.com/data/ibus
